<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chat-daily-tg-channel.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>REPLACE_WITH_PROJECT_DIR/.venv/bin/python</string>
        <string>REPLACE_WITH_PROJECT_DIR/run_channel_daily.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>REPLACE_WITH_PROJECT_DIR</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>10</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>REPLACE_WITH_DATA_DIR/logs/channel-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>REPLACE_WITH_DATA_DIR/logs/channel-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/Apple/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>DEEPSEEK_API_KEY</key>
        <string>REPLACE_WITH_REAL_KEY</string>
        <key>TG_BOT_TOKEN</key>
        <string>REPLACE_WITH_REAL_TOKEN</string>
        <key>TG_CHAT_ID</key>
        <string>REPLACE_WITH_REAL_CHAT_ID</string>
    </dict>
</dict>
</plist>
